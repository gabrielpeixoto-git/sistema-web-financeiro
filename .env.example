# Finanças App - Environment Configuration Example
# Copy this file to .env and adjust the values

# Required
APP_SECRET_KEY=your-secret-key-here-min-32-characters-long

# Database - SQLite (dev)
DATABASE_URL=sqlite:///./dev.db

# Database - PostgreSQL (prod)
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/financas

# Timezone
APP_TIMEZONE=America/Sao_Paulo

# SMTP Configuration for Email Reminders (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TLS=true
EMAIL_REMINDER_DAYS=3

# Notification Settings
NOTIFICATION_BUDGET_NEAR_PERCENT=80
NOTIFICATION_GOAL_NEAR_PERCENT=80
NOTIFICATION_DEDUPE_HOURS=24

# Rate Limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_PER_WINDOW=20
RATE_LIMIT_RESET_PER_WINDOW=10
RATE_LIMIT_IMPORT_PER_WINDOW=5
